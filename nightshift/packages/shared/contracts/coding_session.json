{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent MAXX — Coding Session Contract",
  "description": "Schema for coding session jobs queued via Redis",
  "type": "object",
  "required": ["session_id", "repo_url"],
  "properties": {
    "session_id": { "type": "string", "format": "uuid" },
    "repo_url": { "type": "string", "format": "uri" },
    "prompt": { "type": "string" },
    "task_type": { "type": "string", "enum": ["update", "fix", "feature", "refactor", "test"] },
    "provider_profile": { "type": "string", "default": "balanced" },
    "base_branch": { "type": "string", "default": "main" }
  }
}
