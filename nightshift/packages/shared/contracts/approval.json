{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent MAXX — Approval Contract",
  "type": "object",
  "required": ["run_id", "risk_level", "proposed_command"],
  "properties": {
    "run_id": { "type": "string", "format": "uuid" },
    "risk_level": { "type": "string", "enum": ["none", "low", "medium", "high", "critical"] },
    "proposed_command": { "type": "string" },
    "reason": { "type": "string" }
  }
}
