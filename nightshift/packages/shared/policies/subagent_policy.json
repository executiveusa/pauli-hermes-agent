{
  "title": "Sub-Agent Policy",
  "description": "Constraints for spawned sub-agents",
  "max_concurrent_agents": 5,
  "max_time_budget_minutes": 120,
  "allowed_tools": [
    "terminal", "file_read", "file_write", "file_search", "web_search",
    "web_extract", "execute_code", "browser_navigate"
  ],
  "forbidden_tools": ["delegate_task"],
  "require_repo_scope": true,
  "auto_stop_on_budget_exceeded": true
}
