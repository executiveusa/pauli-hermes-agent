{
  "title": "Browser Policy",
  "description": "Domain allowlist and browser worker constraints",
  "allowed_domains": [
    "github.com", "*.github.com",
    "vercel.com", "*.vercel.app",
    "netlify.com", "*.netlify.app",
    "supabase.com", "*.supabase.co",
    "appwrite.io",
    "coolify.io",
    "google.com", "*.google.com",
    "stackoverflow.com",
    "npmjs.com",
    "pypi.org"
  ],
  "blocked_domains": ["*.onion", "*.tor"],
  "max_concurrent_sessions": 3,
  "max_session_duration_minutes": 30,
  "screenshot_on_error": true,
  "pause_on_captcha": true
}
