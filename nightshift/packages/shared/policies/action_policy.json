{
  "title": "Action Policy",
  "description": "Defines which commands require approval and at what risk level",
  "rules": [
    { "pattern": "rm -rf|drop table|git push --force|git reset --hard", "risk": "critical", "requires_approval": true },
    { "pattern": "docker rm|docker stop|systemctl stop", "risk": "high", "requires_approval": true },
    { "pattern": "git push|npm publish|pip install", "risk": "medium", "requires_approval": true },
    { "pattern": "git commit|git checkout|npm test|pytest", "risk": "low", "requires_approval": false }
  ],
  "default_risk": "medium",
  "auto_approve_below": "medium"
}
