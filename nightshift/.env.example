# ═══════════════════════════════════════════════════
# Agent MAXX — Night Shift Environment Configuration
# ═══════════════════════════════════════════════════

# ── Core ──
APP_NAME=Agent MAXX
APP_ENV=production
API_KEY=change-me-to-a-long-random-string
SECRET_KEY=change-me-another-random-string

# ── Database ──
POSTGRES_USER=maxx
POSTGRES_PASSWORD=maxx_secret
POSTGRES_DB=maxx_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://maxx:maxx_secret@postgres:5432/maxx_db

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Ports ──
API_PORT=8642
DASHBOARD_PORT=3000

# ── Artifacts ──
WORKSPACES_ROOT=/data/workspaces
ARTIFACTS_ROOT=/data/artifacts

# ── Git ──
GITHUB_TOKEN=
GITHUB_ORG=

# ── Provider API Keys ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# ── Provider Router ──
PROVIDER_ROUTER_URL=http://provider-router:8080

# ── Default Models ──
DEFAULT_MODEL_BALANCED=anthropic/claude-sonnet-4-20250514
DEFAULT_MODEL_PREMIUM=anthropic/claude-opus-4-20250514
DEFAULT_MODEL_CODING=anthropic/claude-sonnet-4-20250514
DEFAULT_MODEL_RESEARCH=google/gemini-2.5-flash

# ── Telegram Notifications ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Browser Worker ──
BROWSER_DOMAIN_ALLOWLIST=
BROWSER_MAX_CONCURRENT=3

# ── Appwrite ──
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# ── Scheduler (hours UTC) ──
SCHEDULER_SCAN_HOUR=2
SCHEDULER_PRD_HOUR=3
SCHEDULER_DIGEST_HOUR=7

# ── Hermes API Internal ──
HERMES_API_URL=http://hermes-api:8000

# ── Caddy / Domain ──
DOMAIN=maxx.example.com
