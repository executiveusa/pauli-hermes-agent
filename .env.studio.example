# Hermes Studio — Environment Variables Template
# Copy this to ~/.hermes/.env and fill in your values

# ── Core Provider ──
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# ── Open Brain (Supabase) ──
SUPABASE_URL=http://31.220.58.212:8001
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# ── Mercury 2 (fast inference via OpenRouter) ──
# Uses OPENROUTER_API_KEY above — no separate key needed.
# Model: openrouter/mercury-coder-small or openrouter/mercury-2

# ── Cloudflare ──
CLOUDFLARE_API_TOKEN=

# ── API Server ──
API_SERVER_ENABLED=true
API_SERVER_PORT=8642
API_SERVER_HOST=0.0.0.0
API_SERVER_KEY=

# ── Messaging ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=

# ── Tools ──
FIRECRAWL_API_KEY=
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
FAL_KEY=
ELEVENLABS_API_KEY=
GITHUB_TOKEN=
