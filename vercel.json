{
  "version": 2,
  "buildCommand": "node scripts/build-deploy.js",
  "outputDirectory": "dist",
  "installCommand": "echo 'Static build — no dependencies'",
  "framework": null,
  "routes": [
    { "src": "/dashboard",        "dest": "/dashboard/index.html" },
    { "src": "/dashboard/(.*)",   "dest": "/dashboard/$1" },
    { "src": "/repos.json",       "dest": "/repos.json" },
    { "src": "/(.*)",             "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/repos.json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
