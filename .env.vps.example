# ============================================================
# Hermes Agent — VPS Environment Template
# ============================================================
# Copy to .env and fill in your real values.
# NEVER commit .env to git.
#
# Minimum required for API server + Telegram gateway:
#   ANTHROPIC_API_KEY or OPENAI_API_KEY
#   API_SERVER_KEY       (generate a random secret)
# ============================================================

# ── LLM Providers ─────────────────────────────────────────
# At least one is required. Anthropic is the default provider.
# Get keys from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# MERCURY 2 (OpenRouter) — Low-latency model for voice/real-time
# Get from: https://openrouter.ai/account/api-keys
MERCURY_2_API_TOKEN=

# ── Default model ─────────────────────────────────────────
# Examples:  anthropic/claude-sonnet-4-5  |  openai/gpt-4o
HERMES_MODEL=anthropic/claude-sonnet-4-5

# ── Supabase (Open Brain Database) ────────────────────────
# Runs on this VPS at http://31.220.58.212:8001
# Get keys from Supabase dashboard → Settings → API Keys
SUPABASE_URL=http://31.220.58.212:8001
SUPABASE_KEY=
SUPABASE_SERVICE_KEY=

# ── API Server ────────────────────────────────────────────
# Set to 1 to enable the OpenAI-compatible HTTP API (required for the dashboard)
API_SERVER_ENABLED=1
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8642

# Generate a strong random secret:  openssl rand -hex 32
API_SERVER_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# Allowed origins for the dashboard (comma-separated, no trailing slash)
DASHBOARD_ORIGIN=http://31.220.58.212:9000

# CORS — origins allowed to call the API server from a browser
# Add your Vercel domain + any local dev URLs
API_SERVER_CORS_ORIGINS=https://pauli-hermes-agent.vercel.app,http://localhost:3000,http://localhost:9000

# ── Telegram Gateway (optional) ──────────────────────────
# Get a token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (numeric) — restricts who can use the bot
TELEGRAM_ALLOWED_USERS=

# Default chat the bot posts to
TELEGRAM_HOME_CHANNEL=

# ── Discord Gateway (optional) ────────────────────────────
DISCORD_TOKEN=
DISCORD_HOME_CHANNEL=

# ── Slack Gateway (optional) ─────────────────────────────
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# ── Web Search Tools (optional) ───────────────────────────
# Firecrawl — for web extraction
FIRECRAWL_API_KEY=

# Tavily — for web search
TAVILY_API_KEY=

# Brave Search
BRAVE_API_KEY=

# ── Supabase / Second Brain (pre-filled for VPS at 31.220.58.212) ─────────────
SUPABASE_URL=http://31.220.58.212:8001
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzcyNzc2NjczLCJleHAiOjE5MzA0NTY2NzN9.rl1mc-GgpG6nQArbEfFAKOcMvzL7rrgzPFT-LlCiCy4
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3NzI3NzY2NzMsImV4cCI6MTkzMDQ1NjY3M30.ns9wbGi2xeS2zbZ1foj6fj4NSa4JxSmJKAedmlShF3w
DATABASE_URL=postgresql://postgres:072090156d28a9df6502d94083e47990@31.220.58.212:5434/second_brain

# ── Background Notifications ─────────────────────────────
# Controls verbosity of background process updates:
#   all | result | error | off
HERMES_BACKGROUND_NOTIFICATIONS=result

# ── Max iterations per request ────────────────────────────
HERMES_MAX_ITERATIONS=90

# ── Hermes Home (inside container this is set automatically) ─
# HERMES_HOME=/home/hermes/.hermes
