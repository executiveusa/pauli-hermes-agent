{
  "version": "0.1.0",
  "name": "typography-tokens",
  "description": "Typography tokens for the design system",
  "font-families": {
    "primary": ["Inter", "Geist Sans", "San Serif"],
    "secondary": ["IBM Plex Sans", "Manrope", "Mona Sans"],
    "heading": ["Geist Serif", "Poppins", "Source Serif 3"]
  },
  "type-scale": {
    "display": {
      "desktop": "96px",
      "tablet": "80px",
      "mobile": "72px"
    },
    "h1": {
      "desktop": "56px",
      "tablet": "48px",
      "mobile": "42px"
    },
    "h2": {
      "desktop": "36px",
      "tablet": "32px",
      "mobile": "28px"
    },
    "h3": {
      "desktop": "28px",
      "tablet": "24px",
      "mobile": "22px"
    },
    "body": {
      "desktop": "18px",
      "tablet": "16px",
      "mobile": "15px"
    },
    "caption": {
      "desktop": "14px",
      "tablet": "13px",
      "mobile": "12px"
    }
  },
  "font-weights": {
    "bold": 700,
    "semibold": 600,
    "medium": 500,
    "regular": 400,
    "light": 300
  },
  "line-heights": {
    "tight": 1.2,
    "normal": 1.5,
    "relaxed": 1.6,
    "spacious": 1.75
  },
  "usage": {
    "headings": ["Geist Serif", "Poppins", "Source Serif 3"],
    "body-text": ["Inter", "Geist Sans", "San Serif"],
    "secondary-text": ["IBM Plex Sans", "Manrope", "Mona Sans"],
    "emphasis": ["semibold", "bold"],
    "standard": ["regular", "medium"],
    "subtle": ["light"]
  }
}