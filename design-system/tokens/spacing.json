{
  "version": "0.1.0",
  "name": "spacing-tokens",
  "description": "8-point spacing scale for the design system",
  "scale": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "40px",
    "8": "48px",
    "9": "64px",
    "10": "80px",
    "11": "96px"
  },
  "usage": {
    "inline-elements": ["1", "2", "3"],
    "component-padding": ["2", "3", "4", "5"],
    "section-spacing": ["5", "6", "7", "8"],
    "page-margins": ["5", "6", "8", "9"],
    "container-widths": ["8", "9", "10", "11"]
  },
  "responsive": {
    "mobile": ["2", "3", "4", "5"],
    "tablet": ["3", "4", "5", "6"],
    "desktop": ["4", "5", "6", "7", "8", "9", "10", "11"]
  }
}