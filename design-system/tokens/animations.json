{
  "version": "0.1.0",
  "name": "animation-tokens",
  "description": "Animation timing and easing tokens for design system",
  "durations": {
    "fast": "150ms",
    "normal": "200ms",
    "slow": "300ms",
    "page": "400ms"
  },
  "easing": {
    "ease-in-out": "ease-in-out",
    "cubic-bezier": "cubic-bezier(0.4, 0, 0.2, 1)",
    "ease-out": "ease-out",
    "ease-in": "ease-in"
  },
  "patterns": {
    "fade-in": {
      "duration": "200ms",
      "easing": "ease-in-out",
      "description": "Fade from transparent to opaque"
    },
    "slide-up": {
      "duration": "300ms",
      "easing": "cubic-bezier",
      "description": "Slide up from below with opacity"
    },
    "scale-in": {
      "duration": "150ms",
      "easing": "ease-out",
      "description": "Scale from small to normal size"
    },
    "lift-effect": {
      "duration": "200ms",
      "easing": "ease-out",
      "description": "Elevate element with shadow increase"
    },
    "scale-up": {
      "duration": "150ms",
      "easing": "ease-out",
      "description": "Subtle scale increase on hover"
    },
    "color-shift": {
      "duration": "200ms",
      "easing": "ease-in-out",
      "description": "Smooth color transition"
    },
    "button-press": {
      "duration": "100ms",
      "easing": "ease-in",
      "description": "Quick scale down on press"
    },
    "focus-ring": {
      "duration": "200ms",
      "easing": "ease-out",
      "description": "Expand focus ring on focus"
    }
  },
  "usage": {
    "entrance": ["fade-in", "slide-up", "scale-in"],
    "hover": ["lift-effect", "scale-up", "color-shift"],
    "micro-interactions": ["button-press", "focus-ring"],
    "page-transitions": ["fade-in", "slide-up"],
    "modals": ["fade-in", "scale-in"],
    "navigation": ["slide-up", "fade-in"]
  },
  "accessibility": {
    "respects-reduced-motion": true,
    "media-query": "(prefers-reduced-motion: reduce)",
    "fallback": "none"
  }
}