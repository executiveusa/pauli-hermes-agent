{
  "version": "0.1.0",
  "name": "audit-framework-mapping",
  "description": "Unified audit framework mapping combining multiple audit systems",
  "frameworks": {
    "universal-self-auditing": {
      "source": "Master-prompt-library/UNIVERSAL SELF-AUDITING DESIGN SYSTEM PROMPT 2.1.txt",
      "type": "primary",
      "status": "active"
    },
    "uiux-report": {
      "source": "UIUX-REPORT.md",
      "type": "secondary",
      "status": "migrating"
    },
    "krug-usability": {
      "source": "Master-prompt-library/UIUX Design Review and Recommendations.txt",
      "type": "secondary",
      "status": "migrating"
    }
  },
  "unified-dimensions": {
    "1-clarity": {
      "name": "Clarity",
      "target": 8.0,
      "description": "How clear and understandable is the design? Does it communicate purpose effectively?",
      "sources": ["universal-self-auditing", "uiux-report"],
      "metrics": [
        "Visual hierarchy strength",
        "Information architecture",
        "Purpose communication",
        "Cognitive load"
      ]
    },
    "2-originality": {
      "name": "Originality",
      "target": 7.0,
      "description": "Is the design unique and distinctive? Does it avoid generic patterns?",
      "sources": ["universal-self-auditing", "uiux-report"],
      "metrics": [
        "Unique aesthetic direction",
        "Avoidance of cookie-cutter patterns",
        "Creative choices",
        "Brand differentiation"
      ]
    },
    "3-ethics-alignment": {
      "name": "Ethics Alignment",
      "target": 9.0,
      "description": "Does the design follow ethical principles? Is it honest and transparent?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "No deception or manipulation",
        "Transparent AI disclosure",
        "Respect for user autonomy",
        "Accessibility first"
      ]
    },
    "4-business-viability": {
      "name": "Business Viability",
      "target": 7.0,
      "description": "Is the design feasible and aligned with business goals?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "Implementation feasibility",
        "Cost-effectiveness",
        "Market alignment",
        "ROI potential"
      ]
    },
    "5-implementability": {
      "name": "Implementability",
      "target": 8.0,
      "description": "How easy is it to implement the design technically?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "Technical feasibility",
        "Component availability",
        "Code maintainability",
        "Build complexity"
      ]
    },
    "6-visual-taste": {
      "name": "Visual Taste",
      "target": 9.5,
      "description": "Does the design demonstrate high aesthetic quality?",
      "sources": ["universal-self-auditing", "uiux-report"],
      "metrics": [
        "Typography quality",
        "Color harmony",
        "Spacing precision",
        "Visual polish"
      ]
    },
    "7-conversion-probability": {
      "name": "Conversion Probability",
      "target": 8.0,
      "description": "How likely is the design to convert users?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "CTA clarity",
        "Trust indicators",
        "Value communication",
        "Friction reduction"
      ]
    },
    "8-narrative-strength": {
      "name": "Narrative Strength",
      "target": 7.0,
      "description": "Does the design tell a compelling story?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "Story coherence",
        "Brand voice",
        "Emotional connection",
        "User journey clarity"
      ]
    },
    "9-ux-quality": {
      "name": "UX Quality",
      "target": 9.0,
      "description": "How good is the user experience?",
      "sources": ["universal-self-auditing", "krug-usability"],
      "metrics": [
        "Don't make me think",
        "Consistency",
        "Feedback quality",
        "Recognition over recall",
        "Affordance",
        "Simplicity"
      ]
    },
    "10-accessibility": {
      "name": "Accessibility",
      "target": 9.5,
      "description": "Is the design accessible to all users?",
      "sources": ["universal-self-auditing", "uiux-report", "krug-usability"],
      "metrics": [
        "WCAG AA compliance",
        "Keyboard navigation",
        "Screen reader support",
        "Color contrast",
        "Focus indicators",
        "Touch targets (44px minimum)"
      ]
    },
    "11-performance": {
      "name": "Performance",
      "target": 8.0,
      "description": "How performant is the design?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "Load time < 2s",
        "Animation smoothness",
        "Asset optimization",
        "Lighthouse score ≥ 90"
      ]
    },
    "12-systems-thinking": {
      "name": "Systems Thinking",
      "target": 8.0,
      "description": "Does the design function as a coherent system?",
      "sources": ["universal-self-auditing", "uiux-report"],
      "metrics": [
        "Design system consistency",
        "Token usage",
        "Component reusability",
        "Scalability"
      ]
    },
    "13-feature-completeness": {
      "name": "Feature Completeness",
      "target": 9.0,
      "description": "Are all required features present?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "Core features implemented",
        "Edge cases handled",
        "Error states covered",
        "Loading states present"
      ]
    },
    "14-implementability-realism": {
      "name": "Implementability Realism",
      "target": 8.0,
      "description": "Are implementation estimates realistic?",
      "sources": ["universal-self-auditing"],
      "metrics": [
        "Timeline accuracy",
        "Resource availability",
        "Technical dependencies",
        "Risk assessment"
      ]
    },
    "15-steve-krug-usability": {
      "name": "Steve Krug Usability",
      "target": 9.0,
      "description": "Adherence to 'Don't Make Me Think' principles",
      "sources": ["krug-usability"],
      "metrics": [
        "Primary CTA visible < 3s",
        "Consistent language/colors/spacing",
        "Feedback on all actions",
        "Navigation clues and breadcrumbs",
        "Keyboard navigation",
        "Clear affordance",
        "≤7 top-level options"
      ]
    }
  },
  "target-scores": {
    "minimum-overall": 9.0,
    "minimum-accessibility": 9.5,
    "minimum-performance": 8.0,
    "minimum-ux-quality": 9.0
  },
  "improvement-process": {
    "continuous-learning": true,
    "vector-memory-registration": true,
    "iterative-refinement": true,
    "min-delta-for-refinement": 0.5,
    "max-iterations": 3,
    "human-review-trigger": "After 3 failed iterations"
  },
  "integration": {
    "lighthouse": {
      "performance-target": 90,
      "accessibility-target": 95,
      "best-practices-target": 95,
      "seo-target": 90
    },
    "playwright": {
      "e2e-tests-required": true,
      "keyboard-navigation": true,
      "aria-roles": true,
      "color-contrast": true
    },
    "axe-core": {
      "wcag-level": "AA",
      "auto-fix": false,
      "manual-review": true
    }
  }
}