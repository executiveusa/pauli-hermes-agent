{
  "name": "agent-zero-design-system",
  "version": "0.2.0",
  "description": "Canonical design system for Agent Zero ecosystem with Motion Primitives + TweakCN integration",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx,ts,tsx",
    "test": "vitest",
    "test:accessibility": "playwright test",
    "test:lighthouse": "lighthouse http://localhost:5173 --output html --output-path ./lighthouse-report",
    "generate:css": "node scripts/generate-css-variables.js",
    "generate:tailwind": "node scripts/generate-tailwind-config.js",
    "validate": "node scripts/validate-tokens.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.1.0",
    "lucide-react": "^0.309.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.8",
    "vitest": "^1.1.0",
    "@playwright/test": "^1.40.1",
    "lighthouse": "^11.5.0",
    "axe-core": "^4.8.3",
    "@axe-core/react": "^4.8.3"
  },
  "peerDependencies": {
    "motion": "^10.16.2",
    "tweakcn": "latest"
  },
  "keywords": [
    "design-system",
    "motion-primitives",
    "tweakcn",
    "tailwindcss",
    "radix-ui",
    "accessibility",
    "agent-zero"
  ],
  "author": "Synthia <design@agentzero.eco>",
  "license": "MIT"
}