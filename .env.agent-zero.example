# ============================================================
# Agent Zero — Personal Second Brain
# ============================================================
# Copy to .env.agent-zero and fill in your values.
# This is Bambu's personal agent — separate from Hermes (business).
#
# Start with: docker compose up -d agent-zero
# ============================================================

# ── LLM Provider (inherits from main .env if in same stack) ──
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Model — use a fast model for personal tasks ──────────────
HERMES_MODEL=anthropic/claude-sonnet-4-5

# ── API Server — port 8643 ────────────────────────────────────
API_SERVER_ENABLED=1
API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8643

# Generate a DIFFERENT key from Hermes: openssl rand -hex 32
API_SERVER_KEY=REPLACE_WITH_AGENT_ZERO_SECRET

# CORS — same as Hermes (or restrict to your cockpit only)
API_SERVER_CORS_ORIGINS=https://pauli-hermes-agent.vercel.app,http://localhost:3000

# ── Persona ──────────────────────────────────────────────────
# Forces Agent Zero to load workspace/brain/CONTEXT.md as personal context
AGENT_PERSONA=agent-zero

# ── Supabase — use the 'bambu' schema (NOT 'ivette') ────────
SUPABASE_URL=http://31.220.58.212:8001
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlIiwiaWF0IjoxNzcyNzc2NjczLCJleHAiOjE5MzA0NTY2NzN9.rl1mc-GgpG6nQArbEfFAKOcMvzL7rrgzPFT-LlCiCy4
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaXNzIjoic3VwYWJhc2UiLCJpYXQiOjE3NzI3NzY2NzMsImV4cCI6MTkzMDQ1NjY3M30.ns9wbGi2xeS2zbZ1foj6fj4NSa4JxSmJKAedmlShF3w
DATABASE_URL=postgresql://postgres:072090156d28a9df6502d94083e47990@31.220.58.212:5434/second_brain

# ── Notifications ─────────────────────────────────────────────
HERMES_BACKGROUND_NOTIFICATIONS=result
HERMES_MAX_ITERATIONS=90
